# DeclutrMail v2 — local environment template
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local. The seed scaffold doesn't require any of these
# variables yet — they get added as features land.

# ── Supabase (added when first backend feature lands) ─────────────────
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── App config (added when needed) ────────────────────────────────────
# VITE_APP_ENV=development
# VITE_SITE_URL=http://localhost:5173

# ── Payments (added when billing feature lands) ───────────────────────
# VITE_PADDLE_CLIENT_TOKEN=
# VITE_PADDLE_ENVIRONMENT=sandbox
# VITE_RAZORPAY_KEY_ID=
