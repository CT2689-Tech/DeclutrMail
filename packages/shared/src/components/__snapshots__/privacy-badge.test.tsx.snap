// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PrivacyBadge — D7 + D228 copy contract > card variant > matches the locked SSR snapshot 1`] = `"<section data-dm-privacy-badge="card" aria-label="Full bodies fetched: 0" style="background:#FFFFFF;border:1px solid rgba(0,107,95,0.35);border-radius:12px;box-shadow:0 1px 2px rgba(20,30,50,0.04), 0 0 0 1px rgba(20,30,50,0.012);padding:20px;font-family:var(--dm-font-sans);color:#0E1413"><header style="margin-bottom:12px"><h3 style="margin:0;font-size:16px;font-weight:600;letter-spacing:-0.01em;color:#00463F">Full bodies fetched: 0</h3><p style="margin:6px 0 0;font-size:13px;line-height:1.55;color:#646D69">We never fetch or store the body of your messages. Here is the exact list of what we do store, and what we do not.</p></header><div><div style="font-family:var(--dm-font-mono);font-size:10.5px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#646D69;margin-bottom:6px">We store:</div><ul style="list-style:none;padding:0;margin:0;display:grid;gap:4px"><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#006B5F;margin-top:7px;flex-shrink:0"></span><span>Sender (name + email)</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#006B5F;margin-top:7px;flex-shrink:0"></span><span>Subject</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#006B5F;margin-top:7px;flex-shrink:0"></span><span>Gmail Preview (the short snippet shown in your inbox list)</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#006B5F;margin-top:7px;flex-shrink:0"></span><span>Dates (received)</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#006B5F;margin-top:7px;flex-shrink:0"></span><span>Gmail labels</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#006B5F;margin-top:7px;flex-shrink:0"></span><span>Read/unread state</span></li></ul></div><div style="margin-top:12px"><div style="font-family:var(--dm-font-mono);font-size:10.5px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#646D69;margin-bottom:6px">We never fetch or store:</div><ul style="list-style:none;padding:0;margin:0;display:grid;gap:4px"><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#646D69;margin-top:7px;flex-shrink:0"></span><span>Full message body</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#646D69;margin-top:7px;flex-shrink:0"></span><span>HTML</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#646D69;margin-top:7px;flex-shrink:0"></span><span>Attachments</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#646D69;margin-top:7px;flex-shrink:0"></span><span>Inline images</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#646D69;margin-top:7px;flex-shrink:0"></span><span>Raw MIME</span></li><li style="display:flex;align-items:baseline;gap:8px;font-size:13px;line-height:1.5"><span aria-hidden="true" style="width:5px;height:5px;border-radius:9999px;background:#646D69;margin-top:7px;flex-shrink:0"></span><span>Headers other than the ones above</span></li></ul></div></section>"`;
