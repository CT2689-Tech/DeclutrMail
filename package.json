{
  "name": "declutrmail",
  "version": "0.0.0",
  "private": true,
  "description": "DeclutrMail — Gmail cleanup SaaS. V2 monorepo.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --parallel test",
    "build": "pnpm -r --parallel build",
    "verify-d": "tsx scripts/verify-d.ts",
    "generate-impl-log": "tsx scripts/generate-impl-log.ts",
    "db:migrate": "./scripts/db-migrate.sh",
    "db:migrate:status": "./scripts/db-migrate.sh --status",
    "dev:up": "./scripts/dev-up.sh",
    "dev:down": "./scripts/dev-up.sh --stop",
    "dev:auth": "./scripts/dev-auth.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
