{
  "name": "@declutrmail/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register src/main.ts",
    "start": "node --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register src/main.ts",
    "worker": "node --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register src/worker.ts",
    "worker:dev": "node --watch --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register src/worker.ts",
    "dev-populate": "node --env-file-if-exists=../../.env.local --import @swc-node/register/esm-register scripts/dev-populate-cron.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@declutrmail/db": "workspace:*",
    "@declutrmail/shared": "workspace:*",
    "@declutrmail/workers": "workspace:*",
    "@google-cloud/kms": "^4.5.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@sentry/node": "^10.0.0",
    "bullmq": "^5.34.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.4.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@nestjs/testing": "^10.4.15",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
