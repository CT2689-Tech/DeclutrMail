# DeclutrMail — environment template
# Copy to .env.local and fill in values. Never commit .env.local.
#
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# Active now (PR 1–4)
# -----------------------------------------------------------------------------

# Claude API — local agent runs, optional CI parity testing
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Database (PR 2 — Drizzle + Atlas)
# -----------------------------------------------------------------------------

# Local Postgres (adjust user/host/db to your setup)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/declutrmail

# -----------------------------------------------------------------------------
# Auth & Gmail OAuth (PR 4 — onboarding)
# -----------------------------------------------------------------------------

# Google Cloud Console → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# JWT signing (local dev only — use strong random strings, 32+ chars)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=

# D14 local-dev fallback when KMS is not wired (32-byte hex or base64)
# ENCRYPTION_LOCAL_KEY=

# -----------------------------------------------------------------------------
# Web app (apps/web — Next.js)
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Observability (optional at launch)
# -----------------------------------------------------------------------------

# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
