# DeclutrMail — environment template
#
#   cp .env.example .env.local      # then fill in values
#
# .env.local is gitignored — never commit it. This file (.env.example)
# carries placeholder NAMES only, never real values (CLAUDE.md §10).
#
# Each var is tagged with where it must be configured for deployed envs:
#   [local]  .env.local on the dev machine
#   [gh]     GitHub Actions secret  — repo Settings → Secrets → Actions
#   [gcp]    GCP Secret Manager     — read by Cloud Run at runtime
#
# How to obtain the external-service values: docs/ops/sync-infra-setup.md

# =============================================================================
# Claude API
# =============================================================================

# [local] [gh]  Agent runs + CI parity. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# =============================================================================
# Database (PR 2 — Drizzle + Atlas)
# =============================================================================

# [local]  Local Postgres — adjust user/host/db to your setup.
# Deployed: set DATABASE_URL via [gcp].
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/declutrmail

# =============================================================================
# Gmail OAuth (PR-B) — runbook Step 1
# =============================================================================

# [local] [gh]
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLIENT_ID=

# [local] [gh] [gcp]  — secret
GOOGLE_CLIENT_SECRET=

# [local] [gh]  API-side OAuth callback. Must exactly match an Authorized
# redirect URI on the OAuth client. API runs on port 4000 locally.
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# [local]  Default OFF. The Gmail connect endpoint is unauthenticated until
# the D109/D224 app auth layer exists, so it is disabled (routes 404) unless
# explicitly set to `true`. Set to `true` for local dev / internal testing only.
GMAIL_CONNECT_ENABLED=

# =============================================================================
# OAuth-token encryption (PR-B — D14: Cloud KMS envelope) — runbook Step 2
# =============================================================================

# [gh] [gcp]  Full KMS crypto-key resource name. Used in deployed envs.
# Leave BLANK in .env.local — local dev has no KMS and uses the fallback below.
# Format: projects/<proj>/locations/us-central1/keyRings/declutrmail/cryptoKeys/oauth-token-kek
KMS_KEY_RESOURCE=

# [local]  Local-dev fallback ONLY (D14) — used when KMS_KEY_RESOURCE is unset,
# so devs need no KMS access. 32-byte hex: openssl rand -hex 32
ENCRYPTION_LOCAL_KEY=

# =============================================================================
# Session auth (PR-B) — DeclutrMail's own session JWTs
# =============================================================================

# [local] [gh] [gcp]  — secrets. Strong random strings, 32+ chars.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# =============================================================================
# Redis / BullMQ (PR-C) — runbook Step 3
# =============================================================================

# [local] [gh] [gcp]  — secret. Upstash connection string (rediss://...).
REDIS_URL=

# =============================================================================
# Gmail Pub/Sub (PR-D) — runbook Step 4
# =============================================================================

# [local] [gh]
GMAIL_PUBSUB_TOPIC=
PUBSUB_OIDC_AUDIENCE=
PUBSUB_OIDC_SERVICE_ACCOUNT=

# =============================================================================
# App URLs
# =============================================================================

# [local]  Deployed values differ per environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# =============================================================================
# Observability (D159 — wired in a later PR)
# =============================================================================

# [local] [gh] [gcp]
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
