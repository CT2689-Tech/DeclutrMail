# DeclutrMail — environment template
#
#   cp .env.example .env.local      # then fill in values
#
# .env.local is gitignored — never commit it. This file (.env.example)
# carries placeholder NAMES only, never real values (CLAUDE.md §10).
#
# Each var is tagged with where it must be configured for deployed envs:
#   [local]  .env.local on the dev machine
#   [gh]     GitHub Actions secret  — repo Settings → Secrets → Actions
#   [gcp]    GCP Secret Manager     — read by Cloud Run at runtime
#
# How to obtain the external-service values: docs/ops/sync-infra-setup.md
#
# WORKTREE SETUP. `.env.local` is gitignored, so `git worktree add`
# does NOT copy it. After creating a worktree, run from the MAIN
# checkout:
#
#   ./scripts/sync-env-to-worktree.sh ../wt-<branch-name>
#
# This propagates BOTH the root `.env.local` AND the apps/web one
# (Next.js dev reads from the package CWD, not the repo root). Without
# this step the worktree's `apps/web` dev server fails the AuthProvider
# check (NEXT_PUBLIC_API_URL unset → relative /api/auth/me → Next 404)
# and the API boot crashes on missing JWT/REDIS/KMS secrets.

# =============================================================================
# Claude API
# =============================================================================

# [local] [gh]  Agent runs + CI parity. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# =============================================================================
# Database (PR 2 — Drizzle + Atlas)
# =============================================================================

# [local]  Local Postgres — adjust user/host/db to your setup.
# Deployed: set DATABASE_URL via [gcp].
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/declutrmail

# =============================================================================
# Gmail OAuth (PR-B) — runbook Step 1
# =============================================================================

# [local] [gh]
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLIENT_ID=

# [local] [gh] [gcp]  — secret
GOOGLE_CLIENT_SECRET=

# [local] [gh]  API-side OAuth callback. Must exactly match an Authorized
# redirect URI on the OAuth client. API runs on port 4000 locally.
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# [local]  Default OFF. The Gmail connect endpoint is unauthenticated until
# the D109/D224 app auth layer exists, so it is disabled (routes 404) unless
# explicitly set to `true`. Set to `true` for local dev / internal testing only.
GMAIL_CONNECT_ENABLED=

# [local ONLY]  Dev test-login (D206) — issues a session for an EXISTING user
# WITHOUT Google OAuth so the preview browser / Playwright can smoke full
# authenticated flows. ⚠️ AUTH BYPASS. Triple-gated: requires NODE_ENV!=production
# AND DEV_AUTH_ENABLED=true AND the email to match DEV_AUTH_EMAIL_PREFIX. The API
# REFUSES TO BOOT if DEV_AUTH_ENABLED=true with NODE_ENV=production. NEVER set
# either of these in any deployed env. Usage:
#   GET /api/auth/dev/login?email=<allowlisted-existing-email>
DEV_AUTH_ENABLED=
DEV_AUTH_EMAIL_PREFIX=

# [local + deployed]  Founder allowlist for the operator-facing security-events
# read API (D181 read surface — GET /api/security-events + the /admin/security
# UI). Comma-separated list of exact emails; case-insensitive match. UNSET →
# every admin request 404s (fail-closed). The route is intentionally
# indistinguishable from a non-existent route for non-allowlisted users.
# Local dev: set to your founder email.
# Deployed: configure via GCP Secret Manager.
ADMIN_EMAIL_ALLOWLIST=

# =============================================================================
# OAuth-token encryption (PR-B — D14: Cloud KMS envelope) — runbook Step 2
# =============================================================================

# [gh] [gcp]  Full KMS crypto-key resource name. Used in deployed envs.
# Leave BLANK in .env.local — local dev has no KMS and uses the fallback below.
# Format: projects/<proj>/locations/us-central1/keyRings/declutrmail/cryptoKeys/oauth-token-kek
KMS_KEY_RESOURCE=

# [local]  Local-dev fallback ONLY (D14) — used when KMS_KEY_RESOURCE is unset,
# so devs need no KMS access. 32-byte hex: openssl rand -hex 32
ENCRYPTION_LOCAL_KEY=

# =============================================================================
# Session auth (D155) — DeclutrMail's own session JWTs
# =============================================================================

# [local] [gh] [gcp]  — secrets. Strong random strings, 32+ chars.
# Generate with: openssl rand -base64 48
# Access and refresh secrets MUST DIFFER — same value throws at boot.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# [local] [gh] [gcp]  Web app origin used by OAuth callback redirect.
# Local default: http://localhost:3000. Prod: https://app.declutrmail.com
WEB_URL=http://localhost:3000

# [gcp]  Cookie domain for session + CSRF cookies.
# Local: leave UNSET (defaults to the request host).
# Prod:  .declutrmail.com  (leading dot covers root + subdomains).
COOKIE_DOMAIN=

# =============================================================================
# Redis / BullMQ (PR-C) — runbook Step 3
# =============================================================================

# [local] [gh] [gcp]  — secret. Used by both BullMQ (job queue) and the
# API rate limiter (D156).
#
# LOCAL DEFAULT: redis://localhost:6379 — served by the throwaway
# `redis` container in docker-compose.yml (started by ./scripts/dev-up.sh).
# Do NOT point local dev at Upstash: BullMQ's idle blocking polls
# (BRPOPLPUSH + stalled checks + heartbeats) burn ~700K commands/month
# per worker, blowing past the Upstash free tier inside a few weeks.
#
# PRODUCTION: Upstash connection string (rediss://...) injected via
# [gcp] Secret Manager — never put the prod URL in .env.local.
#
# When unset in dev, the rate limiter fails open and logs a boot
# warning. In production (NODE_ENV=production), an unset REDIS_URL
# throws at boot — per-process in-memory limiting on Cloud Run does not
# share state across instances, so attackers can bypass limits by
# landing on different instances. Override with RATE_LIMIT_ENABLED=false
# to explicitly acknowledge the gap.
REDIS_URL=redis://localhost:6379

# [gcp]  Escape hatch for the rate limiter. Defaults to enabled. Set to
# `false` ONLY to intentionally disable rate limiting in production
# (e.g. Redis outage triage). Any other value (or unset) keeps it on.
RATE_LIMIT_ENABLED=

# [gcp]  BullMQ Worker idle-poll tuning (2026-06-10 Upstash command-volume
# audit). An idle Worker burns 2 Redis commands per drainDelay; Upstash
# bills per command. All four default sanely in code — leave blank for
# local dev. DRAIN_DELAY is SECONDS (bullmq's unit); STALLED_INTERVAL is
# ms and only affects crash-recovery re-queue latency. Job pickup stays
# instant at any drainDelay (Queue.add unblocks the worker's blocking
# pop via BullMQ's marker zset).
#
# User-facing queues (initial-sync / incremental-sync / score /
# label-action). Defaults: 10 / 60000. drainDelay is clamped to <=10s
# in code so pickup polling can never go sluggish.
WORKER_DRAIN_DELAY_SEC=
WORKER_STALLED_INTERVAL_MS=
# Cron queues (brief-snapshot / undo-expiry / senders-counter-
# reconciliation). Defaults: 60 / 300000.
WORKER_CRON_DRAIN_DELAY_SEC=
WORKER_CRON_STALLED_INTERVAL_MS=

# =============================================================================
# Gmail Pub/Sub (PR-D) — runbook Step 4
# =============================================================================

# [local] [gh]
GMAIL_PUBSUB_TOPIC=
PUBSUB_OIDC_AUDIENCE=
PUBSUB_OIDC_SERVICE_ACCOUNT=

# =============================================================================
# App URLs
# =============================================================================

# [local]  Deployed values differ per environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# [local]  INTERIM mailbox identity — read by `apps/web/src/lib/api/client.ts`
# and stamped onto every API request as `x-mailbox-account-id`. The header
# is the placeholder for the proper session layer (D109/D224); once that
# lands, this var is removed. Leave blank and the client falls back to
# the literal 'demo' so Storybook + first-run dev work without setup.
NEXT_PUBLIC_DEMO_MAILBOX_ACCOUNT_ID=

# =============================================================================
# Reasoning worker tuning (D24)
# =============================================================================

# [local] [gh] [gcp]  Per-call timeout for the Haiku `explain()` port, in ms.
# Default 5000. On timeout the worker falls back to the deterministic
# template — the user-visible row still ships, just without the LLM blurb.
REASONING_TIMEOUT_MS=

# [local] [gh] [gcp]  Max concurrent in-flight `explain()` calls during the
# all-senders sweep. Default 4, max 16. Tune up cautiously — Haiku has a
# tenant rate limit and the cap also bounds the worker's peak memory.
REASONING_CONCURRENCY=

# =============================================================================
# Observability (D159)
# =============================================================================
#
# All telemetry is gated on the presence of the relevant key/DSN. With
# every var below blank, the app runs unaffected — Sentry and PostHog
# are completely uninstalled at runtime. This is the canonical local-dev
# posture; deployed envs set them via [gh] / [gcp].
#
# Privacy (D7, D228) is enforced by `packages/shared/src/observability/scrubber.ts`,
# applied both at the call site and in every SDK's `beforeSend` /
# `sanitize_properties` hook. See `docs/observability/event-taxonomy.md`.

# [gh] [gcp]  Sentry server DSN. Read by apps/api at boot. Blank = no-op.
SENTRY_DSN=

# [gh] [gcp]  Optional release identifier surfaced to Sentry (server).
SENTRY_RELEASE=

# [gh] [gcp]  Sentry browser DSN. Distinct project from server is fine.
# `NEXT_PUBLIC_*` is shipped to the browser bundle (Next.js convention).
NEXT_PUBLIC_SENTRY_DSN=

# [gh] [gcp]  Optional release identifier surfaced to Sentry (browser).
NEXT_PUBLIC_SENTRY_RELEASE=

# [gh] [gcp]  PostHog project API key (the public "phc_..." key). Blank = no-op.
NEXT_PUBLIC_POSTHOG_KEY=

# [gh] [gcp]  PostHog ingest host. Default is the US cloud; set to the EU
# host or a self-hosted URL as appropriate. Leave blank for the default.
NEXT_PUBLIC_POSTHOG_HOST=

# -----------------------------------------------------------------------------
# Sentry build-plugin (apps/web — withSentryConfig in next.config.ts)
# -----------------------------------------------------------------------------
# Only needed at BUILD time (Vercel + GitHub Actions); not required at
# runtime. Source-map upload is gated on SENTRY_AUTH_TOKEN — without it
# the build still succeeds but skips upload, which means prod stack
# traces stay minified. ORG + PROJECT identify the destination.
#
# Where to find them:
#   SENTRY_ORG     → Sentry → Settings → Organization → URL slug
#   SENTRY_PROJECT → Sentry → Project → URL slug
#   SENTRY_AUTH_TOKEN → https://sentry.io/settings/account/api/auth-tokens/
#                       (scopes: `project:releases` + `project:write`)

# [gh]  Sentry org slug — read by `withSentryConfig` at build.
SENTRY_ORG=

# [gh]  Sentry project slug — read by `withSentryConfig` at build.
SENTRY_PROJECT=

# [gh] [local-optional]  Sentry auth token (sensitive). Required for
# source-map upload. If absent, build succeeds w/o upload (silently).
SENTRY_AUTH_TOKEN=
